# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Secrets ---
.env
.env.*
!.env.example

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- App data / artifacts (runtime-generated; never commit) ---
.chroma/
storage/
*.sqlite
*.sqlite3
*.db
*.npy

# --- ML artifacts / datasets (never commit large weights or downloaded data) ---
# Downloaded datasets, logs, scratch run outputs and scaled-up weights live here.
artifacts/
# Big model weights anywhere EXCEPT the tiny committed proof checkpoints
# under orchestra/ml/checkpoints/ (kept <25MB so the ML path works out of the box).
*.pt
*.pth
*.onnx
*.ckpt
*.safetensors
!orchestra/ml/checkpoints/*.pt
!orchestra/ml/checkpoints/*.onnx

# --- Editors / OS ---
.idea/
.vscode/
*.swp
.DS_Store
*.log

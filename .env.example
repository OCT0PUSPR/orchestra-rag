# Copy to `.env` and fill in. NEVER commit your real .env.
# All values are optional — the app runs fully offline with the mock backend.

# --- Secrets (used only by the anthropic / huggingface backends) ---
# Get an Anthropic key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get a Hugging Face token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Backend selection ---
# mock (offline, default) | anthropic | huggingface
OARAG_BACKEND=mock

# --- Per-role models (anthropic / huggingface backends) ---
OARAG_PLANNER_MODEL=claude-haiku-4-5
OARAG_RESEARCHER_MODEL=claude-sonnet-4-6
OARAG_CODER_MODEL=claude-opus-4-8
OARAG_CRITIC_MODEL=claude-sonnet-4-6
OARAG_SYNTHESIZER_MODEL=claude-opus-4-8

# --- Retrieval ---
OARAG_K=4
# auto (use sentence-transformers if available, else hashing) | hashing | sentence-transformers
OARAG_EMBEDDER=auto
OARAG_EMBEDDER_DIMENSION=512
# numpy (always available) | chroma
OARAG_STORE=numpy
OARAG_CHUNK_SIZE=180
OARAG_CHUNK_OVERLAP=40

# --- Orchestration ---
# linear | blackboard
OARAG_STRATEGY=linear
OARAG_MAX_ROUNDS=3

# --- Persistence ---
OARAG_STORAGE_DIR=storage
